{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start.mjs\"",
            "timeout": 10,
            "statusMessage": "Loading harness context"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/permission-request.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking permission request"
          }
        ]
      }

    ]
  }
}
